<!-- ════════════════════════════════════════════════
     SCRIPTS
════════════════════════════════════════════════ -->
<script>

// ── CLOCK ─────────────────────────────────────
function updateClock() {
  const now  = new Date();
  const hh   = String(now.getHours()).padStart(2,'0');
  const mm   = String(now.getMinutes()).padStart(2,'0');
  const ss   = String(now.getSeconds()).padStart(2,'0');
  const time = `${hh}:${mm}:${ss}`;
  const el1  = document.getElementById('hud-clock') as HTMLElement;
  const el2  = document.getElementById('footer-time') as HTMLElement;
  if (el1) el1.textContent = time;
  if (el2) el2.textContent = time;
}
setInterval(updateClock, 1000);
updateClock();

// ── BOOT SEQUENCE ─────────────────────────────
const bootLines = [
  '> Iniciando NETWATCH OS v2.077...',
  '> Cargando módulos del sistema...',
  '> [OK] Blockchain interface loaded',
  '> [OK] DeFi protocols connected',
  '> [OK] Smart contract engine ready',
  '> [OK] MEV radar initialized',
  '> Verificando identidad del operativo...',
  '> [OK] HEO-80 — ACCESO CONCEDIDO',
  '> Sistema listo.',
];

const bootLog   = document.getElementById('boot-log') as HTMLElement;
const bootBar   = document.getElementById('boot-bar') as HTMLElement;
const bootEnter = document.getElementById('boot-enter') as HTMLElement;
const bootScreen = document.getElementById('boot-screen') as HTMLElement;
const osShell   = document.getElementById('os-shell') as HTMLElement;

let lineIdx = 0;
function addBootLine() {
  if (lineIdx >= bootLines.length) {
    bootEnter.style.opacity = '1';
    const launch = () => {
      bootScreen.style.transition = 'opacity .6s';
      bootScreen.style.opacity = '0';
      setTimeout(() => {
        bootScreen.style.display = 'none';
        osShell.classList.remove('hidden');
        startHeroTyping();
        startSimTerminal();
      }, 600);
      document.removeEventListener('keydown', launch);
      document.removeEventListener('click', launch);
    };
    document.addEventListener('keydown', launch);
    document.addEventListener('click', launch);
    return;
  }
  const p = document.createElement('p');
  p.className = 'log-line';
  p.textContent = bootLines[lineIdx];
  bootLog.appendChild(p);
  bootBar.style.width = `${((lineIdx+1)/bootLines.length)*100}%`;
  lineIdx++;
  setTimeout(addBootLine, 220 + Math.random()*150);
}
setTimeout(addBootLine, 400);

// ── HERO TYPING ROLES ─────────────────────────
const roles = [
  'Full Stack Developer',
  'DeFi Researcher',
  'Smart Contracts Engineer',
  'Cloud Consultant',
  'Profesor de Programación',
];
let rIdx = 0, cIdx = 0, deleting = false;
const typingEl = document.getElementById('hero-typing') as HTMLElement;

function startHeroTyping() {
  function tick() {
    const word = roles[rIdx];
    if (!deleting) {
      typingEl.textContent = word.substring(0, cIdx + 1);
      cIdx++;
      if (cIdx === word.length) { deleting = true; setTimeout(tick, 1800); return; }
    } else {
      typingEl.textContent = word.substring(0, cIdx - 1);
      cIdx--;
      if (cIdx === 0) { deleting = false; rIdx = (rIdx+1) % roles.length; }
    }
    setTimeout(tick, deleting ? 55 : 90);
  }
  tick();
}

// ── SIMULATED TERMINAL ─────────────────────────
const simLines = [
  { delay: 0,    type: 'cmd',  text: 'whoami' },
  { delay: 400,  type: 'out',  text: 'HEO-80 · Full Stack & DeFi Dev' },
  { delay: 900,  type: 'cmd',  text: 'ls repos/' },
  { delay: 1300, type: 'out',  text: 'DeFi-MEV-Ecosystem/  Flash_Loans/' },
  { delay: 1400, type: 'out',  text: 'Eighterium-Protocol/ CodeTyper/' },
  { delay: 1500, type: 'out',  text: 'monitoring-stack/    apiCamunda/' },
  { delay: 2200, type: 'cmd',  text: 'forge test --match Flash -vv' },
  { delay: 2800, type: 'pass', text: '[PASS] testFlashLoan() · gas: 329850' },
  { delay: 3000, type: 'ok',   text: 'EXITO: Prestamo de 1M WETH devuelto ⚡' },
  { delay: 3800, type: 'cmd',  text: 'git push origin main' },
  { delay: 4200, type: 'out',  text: 'Branch main → github.com/HEO-80' },
  { delay: 4600, type: 'ok',   text: 'SYSTEM STATUS: ONLINE ●' },
];

function startSimTerminal() {
  const body = document.getElementById('sim-terminal') as HTMLElement;
  simLines.forEach(({ delay, type, text }) => {
    setTimeout(() => {
      const p = document.createElement('p');
      if (type === 'cmd') {
        p.innerHTML = `<span style="color:var(--cyan)">$</span> <span style="color:var(--yellow)">${text}</span>`;
      } else if (type === 'pass') {
        p.style.color = 'var(--green)';
        p.textContent = text;
      } else if (type === 'ok') {
        p.style.color = 'var(--green)';
        p.style.textShadow = '0 0 8px var(--green)';
        p.textContent = text;
      } else {
        p.style.color = 'rgba(200,200,210,.65)';
        p.textContent = text;
      }
      body.appendChild(p);
      body.scrollTop = body.scrollHeight;
    }, delay);
  });
}

// ── REAL TERMINAL (xterm.js) ───────────────────
const openBtn     = document.getElementById('open-terminal') as HTMLElement;
const overlay     = document.getElementById('terminal-overlay') as HTMLElement;
const closeBtn    = document.getElementById('close-terminal') as HTMLElement;
const xtermContainer = document.getElementById('xterm-container') as HTMLElement;

let termInstance: any = null;

function openTerminal() {
  overlay.classList.remove('hidden');

  if (termInstance) return;

  // @ts-ignore
  const term = new window.Terminal({
    cursorBlink: true,
    theme: {
      background:  '#060608',
      foreground:  '#c8c8d0',
      cursor:      '#ffcc00',
      black:       '#060608',
      green:       '#00ff41',
      yellow:      '#ffcc00',
      cyan:        '#00ffff',
      magenta:     '#ff00ff',
      red:         '#ff3030',
    },
    fontFamily: "'Share Tech Mono', 'Courier New', monospace",
    fontSize: 14,
    lineHeight: 1.5,
  });

  // @ts-ignore
  const fitAddon = new window.FitAddon.FitAddon();
  term.loadAddon(fitAddon);
  term.open(xtermContainer);
  fitAddon.fit();
  termInstance = term;

  // Welcome message
  term.writeln('\x1b[1;33m╔══════════════════════════════════════════╗\x1b[0m');
  term.writeln('\x1b[1;33m║     NETWATCH OS v2.077  ·  HEO-80        ║\x1b[0m');
  term.writeln('\x1b[1;33m╚══════════════════════════════════════════╝\x1b[0m');
  term.writeln('');
  term.writeln('\x1b[36mComandos disponibles:\x1b[0m');
  term.writeln('  \x1b[33mhelp\x1b[0m       → mostrar comandos');
  term.writeln('  \x1b[33mwhoami\x1b[0m     → perfil del operativo');
  term.writeln('  \x1b[33mprojects\x1b[0m   → listar repositorios');
  term.writeln('  \x1b[33mskills\x1b[0m     → módulos instalados');
  term.writeln('  \x1b[33mcontact\x1b[0m    → canales de comunicación');
  term.writeln('  \x1b[33mstatus\x1b[0m     → estado del sistema');
  term.writeln('  \x1b[33mclear\x1b[0m      → limpiar pantalla');
  term.writeln('');

  let input = '';
  term.write('\x1b[32mnetwatch@HEO-80\x1b[0m:\x1b[33m~\x1b[0m$ ');

  term.onKey(({ key, domEvent }: { key: string; domEvent: KeyboardEvent }) => {
    const code = domEvent.keyCode;
    if (code === 13) { // Enter
      term.writeln('');
      handleCommand(term, input.trim());
      input = '';
      term.write('\x1b[32mnetwatch@HEO-80\x1b[0m:\x1b[33m~\x1b[0m$ ');
    } else if (code === 8) { // Backspace
      if (input.length > 0) {
        input = input.slice(0, -1);
        term.write('\b \b');
      }
    } else {
      input += key;
      term.write(key);
    }
  });
}

function handleCommand(term: any, cmd: string) {
  switch(cmd.toLowerCase()) {
    case 'help':
      term.writeln('\x1b[36mComandos:\x1b[0m help · whoami · projects · skills · contact · status · clear');
      break;
    case 'whoami':
      term.writeln('\x1b[33mHéctor Oviedo\x1b[0m — Full Stack Dev & DeFi Researcher');
      term.writeln('📍 Zaragoza, España · github.com/HEO-80');
      break;
    case 'projects':
      term.writeln('\x1b[36mRepositorios activos:\x1b[0m');
      term.writeln('  ⚡ DeFi-MEV-Ecosystem   → MEV · Flash Loans · Arbitrage');
      term.writeln('  ⚡ Flash_Loans          → Aave V3 · Ethereum Mainnet');
      term.writeln('  ∞  Eighterium-Protocol  → Pagos programables · DAO');
      term.writeln('  🖥 CodeTyper            → Mecanografía para código');
      term.writeln('  📡 monitoring-stack     → Grafana · Prometheus · Docker');
      break;
    case 'skills':
      term.writeln('\x1b[36mMódulos instalados:\x1b[0m');
      term.writeln('  Solidity · Foundry · Aave · Uniswap · MEV');
      term.writeln('  C# · .NET · Azure · Docker · Node.js');
      term.writeln('  React · Next.js · Astro · GSAP · TypeScript');
      break;
    case 'contact':
      term.writeln('\x1b[36mCanales de comunicación:\x1b[0m');
      term.writeln('  LinkedIn → linkedin.com/in/hectorob');
      term.writeln('  GitHub   → github.com/HEO-80');
      term.writeln('  Email    → eovertigo@gmail.com');
      break;
    case 'status':
      term.writeln('\x1b[32m[OK]\x1b[0m NETWATCH OS v2.077 · ONLINE');
      term.writeln('\x1b[32m[OK]\x1b[0m DeFi protocols connected');
      term.writeln('\x1b[32m[OK]\x1b[0m Smart contract engine ready');
      term.writeln('\x1b[32m[OK]\x1b[0m MEV radar initialized');
      break;
    case 'clear':
      term.clear();
      break;
    case '':
      break;
    default:
      term.writeln(`\x1b[31mcomando no encontrado:\x1b[0m ${cmd} · escribe \x1b[33mhelp\x1b[0m`);
  }
}

function closeTerminal() {
  overlay.classList.add('hidden');
}

openBtn.addEventListener('click', openTerminal);
closeBtn.addEventListener('click', closeTerminal);
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeTerminal();
});
</script>