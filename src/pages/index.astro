---
import Layout from "../layouts/Layout.astro";
---

<Layout>

  <!-- ═══ BOOT SCREEN ═══ -->
  <div id="boot-screen">
    <div class="boot-inner">
      <div class="boot-logo">
        <span class="boot-bracket">[</span>
        <span class="boot-heo glitch" data-text="HEO-80">HEO-80</span>
        <span class="boot-bracket">]</span>
      </div>
      <div class="boot-log" id="boot-log"></div>
      <div class="boot-bar-wrap">
        <div class="boot-bar" id="boot-bar"></div>
      </div>
      <div class="boot-enter" id="boot-enter">
        <span>▶ PRESS ANY KEY TO INITIALIZE</span>
      </div>
    </div>
  </div>

  <!-- ═══ MAIN OS ═══ -->
  <div id="os-shell" class="hidden">

    <!-- TOP BAR / HUD -->
    <header class="hud-bar">
      <div class="hud-left">
        <span class="hud-logo">⬡ NETWATCH<span class="hud-ver">OS v2.077</span></span>
      </div>
      <nav class="hud-nav">
        <a href="#hero"      class="hud-link" data-text="INICIO">INICIO</a>
        <a href="#projects"  class="hud-link" data-text="PROYECTOS">PROYECTOS</a>
        <a href="#skills"    class="hud-link" data-text="SKILLS">SKILLS</a>
        <a href="#about"     class="hud-link" data-text="ABOUT">ABOUT</a>
        <a href="#contact"   class="hud-link" data-text="CONTACTO">CONTACTO</a>
        <button class="hud-terminal-btn" id="open-terminal">
          <span class="btn-icon">⌨</span> TERMINAL
        </button>
      </nav>
      <div class="hud-right">
        <span class="hud-status">
          <span class="status-dot"></span>ONLINE
        </span>
        <span class="hud-time" id="hud-clock">00:00:00</span>
      </div>
    </header>

    <!-- ═══ HERO SECTION ═══ -->
    <section id="hero" class="hero-section">
      <div class="hero-content">
        <div class="hero-tag">// IDENTIFICACIÓN DE OPERATIVO</div>
        <h1 class="hero-name glitch" data-text="HÉCTOR OVIEDO">HÉCTOR OVIEDO</h1>
        <div class="hero-roles">
          <span class="role-prefix">&gt; </span>
          <span id="hero-typing" class="hero-typing"></span>
          <span class="hero-cursor">█</span>
        </div>
        <p class="hero-desc">
          Full Stack Dev · DeFi Researcher · Smart Contracts · Cloud<br/>
          <span class="hero-loc">📍 Zaragoza, España</span>
        </p>
        <div class="hero-ctas">
          <a href="#projects" class="btn-cyber btn-primary">
            <span class="btn-text">VER PROYECTOS</span>
            <span class="btn-glitch" aria-hidden="true">VER PROYECTOS</span>
          </a>
          <a href="#contact" class="btn-cyber btn-secondary">
            <span class="btn-text">CONTACTO</span>
            <span class="btn-glitch" aria-hidden="true">CONTACTO</span>
          </a>
          <a href="https://github.com/HEO-80" target="_blank" class="btn-cyber btn-ghost">
            <span class="btn-text">⬡ GITHUB</span>
          </a>
        </div>
      </div>

      <!-- HERO SIDE — Simulated terminal -->
      <div class="hero-terminal">
        <div class="term-titlebar">
          <div class="term-dots">
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green"></span>
          </div>
          <span class="term-title">netwatch@HEO-80 ~ powershell</span>
        </div>
        <div class="term-body" id="sim-terminal"></div>
      </div>
    </section>

    <!-- ═══ PROJECTS SECTION ═══ -->
    <section id="projects" class="section">
      <div class="section-header">
        <span class="section-tag">// REPOSITORIOS ACTIVOS</span>
        <h2 class="section-title glitch" data-text="PROYECTOS">PROYECTOS</h2>
      </div>
      <div class="projects-grid">

        <div class="project-card card-featured">
          <div class="card-header">
            <span class="card-tag">⚡ DeFi · MEV</span>
            <span class="card-status status-active">● ACTIVO</span>
          </div>
          <h3 class="card-title">DeFi-MEV-Ecosystem</h3>
          <p class="card-desc">Ecosistema completo de MEV — Flash Loans, arbitraje multi-token, sniping, radar WSS y Dark Forest routing en BSC.</p>
          <div class="card-stack">
            <span class="tag">Solidity</span><span class="tag">Foundry</span><span class="tag">Aave V3</span><span class="tag">Uniswap V3</span>
          </div>
          <a href="https://github.com/HEO-80/DeFi-MEV-Ecosystem" target="_blank" class="card-link">
            ACCEDER AL REPO →
          </a>
        </div>

        <div class="project-card">
          <div class="card-header">
            <span class="card-tag">⚡ Flash Loans</span>
            <span class="card-status status-active">● ACTIVO</span>
          </div>
          <h3 class="card-title">Flash Loans · Aave V3</h3>
          <p class="card-desc">Receptor de Flash Loans en Ethereum Mainnet. 1M WETH prestado y devuelto en un único bloque. Tests con Foundry fork.</p>
          <div class="card-stack">
            <span class="tag">Solidity</span><span class="tag">Foundry</span><span class="tag">Fork test</span>
          </div>
          <a href="https://github.com/HEO-80/Flash_Loans" target="_blank" class="card-link">ACCEDER AL REPO →</a>
        </div>

        <div class="project-card">
          <div class="card-header">
            <span class="card-tag">∞ Protocol</span>
            <span class="card-status status-wip">◐ EN DESARROLLO</span>
          </div>
          <h3 class="card-title">Eighterium Protocol</h3>
          <p class="card-desc">Protocolo de pagos programables con reserva mínima del 8% garantizada on-chain. Escrow, hitos, DAO de árbitros.</p>
          <div class="card-stack">
            <span class="tag">Solidity</span><span class="tag">ERC-20</span><span class="tag">DAO</span>
          </div>
          <a href="https://github.com/HEO-80" target="_blank" class="card-link">ACCEDER AL REPO →</a>
        </div>

        <div class="project-card">
          <div class="card-header">
            <span class="card-tag">🖥 Dev Tool</span>
            <span class="card-status status-active">● LIVE</span>
          </div>
          <h3 class="card-title">CodeTyper</h3>
          <p class="card-desc">App de mecanografía para código real con tokenización semántica en tiempo real. Igual que tu IDE.</p>
          <div class="card-stack">
            <span class="tag">Next.js</span><span class="tag">React</span><span class="tag">Tokenizer</span>
          </div>
          <a href="https://github.com/HEO-80/CodeTyper" target="_blank" class="card-link">ACCEDER AL REPO →</a>
        </div>

        <div class="project-card">
          <div class="card-header">
            <span class="card-tag">🔗 BPM · Backend</span>
            <span class="card-status status-active">● ACTIVO</span>
          </div>
          <h3 class="card-title">API Camunda</h3>
          <p class="card-desc">Automatización de procesos empresariales con Camunda BPM. Backend .NET + Angular frontend.</p>
          <div class="card-stack">
            <span class="tag">.NET</span><span class="tag">Camunda</span><span class="tag">Angular</span>
          </div>
          <a href="https://github.com/HEO-80/apiCamunda" target="_blank" class="card-link">ACCEDER AL REPO →</a>
        </div>

        <div class="project-card">
          <div class="card-header">
            <span class="card-tag">📡 DevOps</span>
            <span class="card-status status-active">● ACTIVO</span>
          </div>
          <h3 class="card-title">Monitoring Stack</h3>
          <p class="card-desc">Stack de monitorización con Grafana + Prometheus + Docker. Métricas en tiempo real para servicios cloud.</p>
          <div class="card-stack">
            <span class="tag">Docker</span><span class="tag">Grafana</span><span class="tag">Prometheus</span>
          </div>
          <a href="https://github.com/HEO-80/monitoring-stack" target="_blank" class="card-link">ACCEDER AL REPO →</a>
        </div>

      </div>
    </section>

    <!-- ═══ SKILLS SECTION ═══ -->
    <section id="skills" class="section">
      <div class="section-header">
        <span class="section-tag">// MÓDULOS INSTALADOS</span>
        <h2 class="section-title glitch" data-text="SKILLS">SKILLS</h2>
      </div>
      <div class="skills-grid">
        <div class="skill-module">
          <div class="skill-icon">⛓</div>
          <h3 class="skill-name">Blockchain · DeFi</h3>
          <div class="skill-bar"><div class="skill-fill" style="--pct:82%"></div></div>
          <p class="skill-tags">Solidity · Foundry · Aave · Uniswap · MEV · Flash Loans</p>
        </div>
        <div class="skill-module">
          <div class="skill-icon">⚙</div>
          <h3 class="skill-name">Backend · Cloud</h3>
          <div class="skill-bar"><div class="skill-fill" style="--pct:90%"></div></div>
          <p class="skill-tags">C# · .NET · Azure · Docker · PostgreSQL · Node.js</p>
        </div>
        <div class="skill-module">
          <div class="skill-icon">◈</div>
          <h3 class="skill-name">Frontend</h3>
          <div class="skill-bar"><div class="skill-fill" style="--pct:85%"></div></div>
          <p class="skill-tags">React · Next.js · Astro · TypeScript · GSAP · Tailwind</p>
        </div>
        <div class="skill-module">
          <div class="skill-icon">📡</div>
          <h3 class="skill-name">DevOps · Infra</h3>
          <div class="skill-bar"><div class="skill-fill" style="--pct:75%"></div></div>
          <p class="skill-tags">Docker · Grafana · Prometheus · CI/CD · Linux</p>
        </div>
        <div class="skill-module">
          <div class="skill-icon">📱</div>
          <h3 class="skill-name">Mobile</h3>
          <div class="skill-bar"><div class="skill-fill" style="--pct:70%"></div></div>
          <p class="skill-tags">React Native · Expo · Flutter · Android Studio</p>
        </div>
        <div class="skill-module">
          <div class="skill-icon">🎓</div>
          <h3 class="skill-name">Docencia</h3>
          <div class="skill-bar"><div class="skill-fill" style="--pct:95%"></div></div>
          <p class="skill-tags">Frontend 300h · React · Astro · Next.js · GSAP</p>
        </div>
      </div>
    </section>

    <!-- ═══ ABOUT SECTION ═══ -->
    <section id="about" class="section">
      <div class="section-header">
        <span class="section-tag">// PERFIL DEL OPERATIVO</span>
        <h2 class="section-title glitch" data-text="ABOUT">ABOUT</h2>
      </div>
      <div class="about-grid">
        <div class="about-text">
          <p>Full Stack Developer con especialización creciente en <span class="highlight">DeFi y Smart Contracts</span>. Profesor de programación con experiencia impartiendo cursos de 300h en tecnologías modernas.</p>
          <p>Construyendo el puente entre el <span class="highlight">desarrollo web tradicional</span> y el ecosistema <span class="highlight">Web3/DeFi</span> — desde contratos Solidity en Ethereum Mainnet hasta interfaces Cyberpunk con Astro y GSAP.</p>
          <p>Actualmente desarrollando el <span class="highlight">Eighterium Protocol</span> — pagos programables con garantías on-chain para Europa.</p>
          <div class="about-stats">
            <div class="stat">
              <span class="stat-num">24+</span>
              <span class="stat-label">Repos públicos</span>
            </div>
            <div class="stat">
              <span class="stat-num">300h</span>
              <span class="stat-label">Cursos impartidos</span>
            </div>
            <div class="stat">
              <span class="stat-num">1M</span>
              <span class="stat-label">WETH en Flash Loan</span>
            </div>
            <div class="stat">
              <span class="stat-num">8%</span>
              <span class="stat-label">Reserve mínima Eighterium</span>
            </div>
          </div>
        </div>
        <div class="about-terminal-mini">
          <div class="term-titlebar">
            <div class="term-dots">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
            </div>
            <span class="term-title">whoami.sh</span>
          </div>
          <div class="term-body about-term-body">
            <p><span class="t-prompt">$</span> <span class="t-cmd">cat profile.json</span></p>
            <p class="t-out">{</p>
            <p class="t-out">&nbsp;&nbsp;"name": <span class="t-str">"Héctor Oviedo"</span>,</p>
            <p class="t-out">&nbsp;&nbsp;"role": <span class="t-str">"Full Stack + DeFi"</span>,</p>
            <p class="t-out">&nbsp;&nbsp;"location": <span class="t-str">"Zaragoza, ES"</span>,</p>
            <p class="t-out">&nbsp;&nbsp;"focus": [</p>
            <p class="t-out">&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-str">"Smart Contracts"</span>,</p>
            <p class="t-out">&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-str">"MEV · DeFi"</span>,</p>
            <p class="t-out">&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-str">"Cloud · Azure"</span></p>
            <p class="t-out">&nbsp;&nbsp;],</p>
            <p class="t-out">&nbsp;&nbsp;"status": <span class="t-green">"available"</span></p>
            <p class="t-out">}</p>
            <p class="t-blank">&nbsp;</p>
            <p><span class="t-prompt">$</span> <span class="t-cmd">_</span><span class="hero-cursor">█</span></p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ CONTACT SECTION ═══ -->
    <section id="contact" class="section">
      <div class="section-header">
        <span class="section-tag">// CANAL DE COMUNICACIÓN</span>
        <h2 class="section-title glitch" data-text="CONTACTO">CONTACTO</h2>
      </div>
      <div class="contact-grid">
        <a href="https://www.linkedin.com/in/hectorob/" target="_blank" class="contact-card">
          <span class="contact-icon">in</span>
          <span class="contact-label">LinkedIn</span>
          <span class="contact-sub">hectorob</span>
        </a>
        <a href="https://github.com/HEO-80" target="_blank" class="contact-card">
          <span class="contact-icon">⬡</span>
          <span class="contact-label">GitHub</span>
          <span class="contact-sub">HEO-80</span>
        </a>
        <a href="https://landing-page-react-hector.vercel.app" target="_blank" class="contact-card">
          <span class="contact-icon">◈</span>
          <span class="contact-label">Portfolio</span>
          <span class="contact-sub">Vercel · Live</span>
        </a>
        <a href="mailto:eovertigo@gmail.com" class="contact-card">
          <span class="contact-icon">@</span>
          <span class="contact-label">Email</span>
          <span class="contact-sub">eovertigo@gmail.com</span>
        </a>
      </div>
    </section>

    <!-- ═══ FOOTER ═══ -->
    <footer class="cyber-footer">
      <div class="footer-scan"></div>
      <div class="footer-content">
        <span class="footer-left">NETWATCH OS v2.077 · HEO-80 · Zaragoza, España</span>
        <span class="footer-right">SYSTEM STATUS: <span class="t-green">ONLINE</span> · <span id="footer-time">--:--:--</span></span>
      </div>
    </footer>

  </div><!-- /os-shell -->

  <!-- ═══ REAL TERMINAL OVERLAY ═══ -->
  <div id="terminal-overlay" class="terminal-overlay hidden">
    <div class="real-terminal-window">
      <div class="term-titlebar">
        <div class="term-dots">
          <span class="dot dot-red" id="close-terminal"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </div>
        <span class="term-title">⌨ NETWATCH TERMINAL — powershell · HEO-80</span>
        <span class="term-close-hint">ESC para cerrar</span>
      </div>
      <div id="xterm-container"></div>
    </div>
  </div>

</Layout>

<!-- ════════════════════════════════════════════════
     STYLES
════════════════════════════════════════════════ -->
<style>

/* ── HUD BAR ─────────────────────────────────── */
.hud-bar {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 56px;
  background: rgba(6,6,8,0.92);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 2rem;
  z-index: 1000;
  backdrop-filter: blur(12px);
  box-shadow: 0 0 30px rgba(255,204,0,0.08);
}
.hud-bar::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  height: 1px; width: 100%;
  background: linear-gradient(90deg, transparent, var(--yellow), transparent);
  animation: hud-scan 4s linear infinite;
}
@keyframes hud-scan {
  from { transform: translateX(-100%); }
  to   { transform: translateX(100%); }
}
.hud-logo {
  font-family: var(--font-hud);
  font-size: .85rem;
  font-weight: 900;
  color: var(--yellow);
  letter-spacing: 3px;
  text-shadow: 0 0 12px var(--yellow);
}
.hud-ver {
  font-size: .6rem;
  color: var(--cyan);
  margin-left: .5rem;
  opacity: .7;
}
.hud-nav {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}
.hud-link {
  font-family: var(--font-hud);
  font-size: .65rem;
  font-weight: 700;
  color: rgba(255,204,0,.6);
  text-decoration: none;
  letter-spacing: 2px;
  transition: color .2s;
  position: relative;
}
.hud-link:hover { color: var(--yellow); text-shadow: 0 0 8px var(--yellow); }
.hud-terminal-btn {
  font-family: var(--font-hud);
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: 2px;
  background: transparent;
  border: 1px solid var(--cyan);
  color: var(--cyan);
  padding: .35rem .9rem;
  cursor: pointer;
  clip-path: polygon(6px 0,100% 0,calc(100% - 6px) 100%,0 100%);
  transition: all .2s;
}
.hud-terminal-btn:hover {
  background: var(--cyan);
  color: var(--bg);
  box-shadow: 0 0 16px var(--cyan);
}
.hud-right {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  font-family: var(--font-mono);
  font-size: .7rem;
}
.status-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 8px var(--green);
  display: inline-block;
  margin-right: .4rem;
  animation: pulse-dot 2s infinite;
}
@keyframes pulse-dot {
  0%,100% { opacity:1; }
  50% { opacity:.4; }
}
.hud-status { color: var(--green); }
.hud-time { color: var(--cyan); opacity: .8; }

/* ── BOOT SCREEN ─────────────────────────────── */
#boot-screen {
  position: fixed;
  inset: 0;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9998;
  flex-direction: column;
}
.boot-inner {
  width: min(600px, 90vw);
  font-family: var(--font-mono);
}
.boot-logo {
  font-family: var(--font-hud);
  font-size: clamp(2.5rem,8vw,5rem);
  font-weight: 900;
  text-align: center;
  margin-bottom: 3rem;
  letter-spacing: 8px;
}
.boot-bracket { color: var(--cyan); }
.boot-heo { color: var(--yellow); text-shadow: 0 0 20px var(--yellow); }
.boot-log {
  font-size: .8rem;
  color: var(--green);
  height: 160px;
  overflow: hidden;
  margin-bottom: 1.5rem;
  line-height: 1.8;
}
.boot-log .log-line { opacity: 0; animation: fade-line .3s forwards; }
@keyframes fade-line { to { opacity:1; } }
.boot-bar-wrap {
  height: 3px;
  background: rgba(255,204,0,.15);
  margin-bottom: 2rem;
  overflow: hidden;
}
.boot-bar {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, var(--yellow), var(--cyan));
  box-shadow: 0 0 10px var(--yellow);
  transition: width .05s linear;
}
.boot-enter {
  text-align: center;
  font-size: .85rem;
  color: var(--cyan);
  opacity: 0;
  animation: boot-blink 1s infinite;
  letter-spacing: 2px;
}
@keyframes boot-blink {
  0%,100% { opacity:1; }
  50% { opacity:0; }
}

/* ── HERO ────────────────────────────────────── */
.hero-section {
  min-height: 100vh;
  padding: 80px 4rem 4rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  position: relative;
  z-index: 1;
}
.hero-tag {
  font-family: var(--font-mono);
  font-size: .75rem;
  color: var(--cyan);
  letter-spacing: 2px;
  margin-bottom: 1rem;
  opacity: .7;
}
.hero-name {
  font-family: var(--font-hud);
  font-size: clamp(2.5rem,5vw,4.5rem);
  font-weight: 900;
  color: var(--yellow);
  text-shadow: 0 0 20px rgba(255,204,0,.4);
  letter-spacing: 4px;
  margin-bottom: 1.5rem;
  line-height: 1;
}
.hero-roles {
  font-family: var(--font-mono);
  font-size: clamp(1rem,2vw,1.3rem);
  color: var(--cyan);
  margin-bottom: 1.5rem;
  min-height: 2rem;
}
.role-prefix { color: var(--green); }
.hero-cursor {
  display: inline-block;
  animation: cursor-blink .6s infinite;
  color: var(--yellow);
}
@keyframes cursor-blink {
  0%,49% { opacity:1; }
  50%,100% { opacity:0; }
}
.hero-desc {
  font-size: 1rem;
  color: var(--text);
  line-height: 1.7;
  margin-bottom: 2.5rem;
  opacity: .8;
}
.hero-loc { color: var(--yellow); opacity: .7; font-size: .85rem; }
.hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

/* ── BUTTONS ─────────────────────────────────── */
.btn-cyber {
  position: relative;
  font-family: var(--font-hud);
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-decoration: none;
  padding: .75rem 1.75rem;
  clip-path: polygon(8px 0,100% 0,calc(100%-8px) 100%,0 100%);
  overflow: hidden;
  transition: all .2s;
  display: inline-block;
}
.btn-primary {
  background: var(--yellow);
  color: var(--bg);
  box-shadow: 0 0 20px rgba(255,204,0,.3);
}
.btn-primary:hover {
  box-shadow: 0 0 30px rgba(255,204,0,.6);
  transform: translateY(-2px);
}
.btn-secondary {
  background: transparent;
  color: var(--cyan);
  border: 1px solid var(--cyan);
  box-shadow: 0 0 10px rgba(0,255,255,.2);
